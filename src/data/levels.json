      "tutorial": "Welcome to Dungeon Shift! This tutorial will teach you everything you need to know.",
      "tutorialSteps": [
        {
          "step": 1,
          "trigger": "manual",
          "message": "Welcome to Dungeon Shift! This is a puzzle game where the dungeon shifts after every move. Let's learn the basics!",
          "highlight": "player"
        },
        {
          "step": 2,
          "trigger": "manual",
          "message": "Use ARROW KEYS or WASD to move your character. Try moving now!",
          "highlight": "player"
        },
        {
          "step": 3,
          "trigger": "manual",
          "message": "Great! Notice the MOVES counter at the top left. You have limited moves per level!",
          "highlight": "hud"
        },
        {
          "step": 4,
          "trigger": "manual",
          "message": "See your HP (hearts) at the top? You have 3 health points. Taking damage reduces your HP!",
          "highlight": "hud"
        },
        {
          "step": 5,
          "trigger": "manual",
          "message": "After each move, the dungeon SHIFTS! The map is divided into 4 QUADRANTS that swap positions.",
          "highlight": "grid"
        },
        {
          "step": 6,
          "trigger": "manual",
          "message": "Look at the 'Next Shift' box on the right. The 4 squares represent the 4 quadrants of this map!",
          "highlight": "shift"
        },
        {
          "step": 7,
          "trigger": "manual",
          "message": "The colored arrows show which quadrants will SWAP. Top-Left ↔ Bottom-Right, Top-Right ↔ Bottom-Left!",
          "highlight": "shift"
        },
        {
          "step": 8,
          "trigger": "manual",
          "message": "Gray blocks are WALLS. You cannot walk through them. Plan your path carefully!",
          "highlight": "walls"
        },
        {
          "step": 9,
          "trigger": "manual",
          "message": "The yellow icon is a KEY. Collect keys to unlock the exit! Now explore and collect the key!",
          "highlight": "key"
        },
        {
          "step": 10,
          "trigger": "keyCollected",
          "message": "Excellent! You collected the key. Check the key counter at the top!",
          "highlight": "hud"
        },
        {
          "step": 11,
          "trigger": "manual",
          "message": "Gray spikes are SPIKE TRAPS. They damage you when you step on them. Avoid them!",
          "highlight": "trap"
        },
        {
          "step": 12,
          "trigger": "manual",
          "message": "Red enemies are PATROLLERS. They move along set paths. Don't touch them or you'll take damage!",
          "highlight": "enemy"
        },
        {
          "step": 13,
          "trigger": "manual",
          "message": "Press [U] or click the UNDO button (bottom-left) to undo moves. You have 5 undos per level!",
          "highlight": "undo"
        },
        {
          "step": 14,
          "trigger": "manual",
          "message": "Press [H] or click HINT button for help. You get 1 hint per level (reduces undos to 3)!",
          "highlight": "hint"
        },
        {
          "step": 15,
          "trigger": "manual",
          "message": "Press [P] for SOLUTION (bottom-right). Solutions unlock after completing a level once!",
          "highlight": "solution"
        },
        {
          "step": 16,
          "trigger": "manual",
          "message": "Press [ESC] to open the PAUSE MENU (top-right). You can restart or quit from there!",
          "highlight": "pause"
        },
        {
          "step": 17,
          "trigger": "manual",
          "message": "Press [M] to MUTE/UNMUTE audio (top-right). Toggle sound effects and music anytime!",
          "highlight": "mute"
        },
        {
          "step": 18,
          "trigger": "manual",
          "message": "The purple portal is the EXIT. Reach it with all required keys to win!",
          "highlight": "exit"
        },
        {
          "step": 19,
          "trigger": "manual",
          "message": "That's everything! Now complete this tutorial level. Good luck!",
          "highlight": "none"
        }
      ]
    },
